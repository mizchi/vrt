{
  "name": "vrt",
  "version": "0.4.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "vrt": "./dist/vrt.mjs"
  },
  "exports": {
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm build",
    "test": "node --test src/**/*.test.ts",
    "demo": "node src/demo.ts",
    "demo:fix": "node src/demo-fix-loop.ts",
    "demo:multi": "node src/demo-scenarios.ts",
    "demo:multistep": "node src/demo-multistep.ts",
    "vrt": "playwright test",
    "vrt:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.19.12",
    "@playwright/test": "^1.52.0",
    "hono": "^4.12.10",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "ws": "^8.20.0"
  }
}
